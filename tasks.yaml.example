# tasks.yaml — manifest for the multi-agent orchestrator
#
# Used by .claude/agents/coordinator.md when invoked via /orchestrate.
# Copy to tasks.yaml, fill in real tasks, then run: /orchestrate tasks.yaml
#
# Schema:
#   id              — short identifier, used as branch/worktree name (orch/<id>, .claude-worktrees/<id>)
#   description     — one paragraph for the implementer
#   acceptance_tests — list of shell commands that must exit 0 for the task to be green
#   dependencies    — task ids that must finish green before this one starts (default: [])
#   paths_touched   — rough list — coordinator uses these to detect collisions and serialize overlapping tasks

tasks:
  - id: T1
    description: |
      Add a `corrective_action_required` boolean to the temp_log_readings table and
      surface it in the API + UI. Out-of-range readings without a corrective note must
      return 422 needs_corrective_action; with a note, status=yellow not red.
    acceptance_tests:
      - npm run test:temp-log-rules
      - npm run test:temp-log-api
      - npm run test:temp-log-route
    dependencies: []
    paths_touched:
      - lib/tempLog.ts
      - app/api/temp-log/route.js
      - app/food-safety/temp-log/

  - id: T2
    description: |
      Wire vendor-price-shock detection into the costing ingest so abnormal price
      jumps (>2σ over 4-week trailing average) flag a row in price_shocks.
      Shock detection logic already lives in scripts/lib/price_shocks.py — wire it
      from scripts/ingest-costing.mjs after the existing T8 shrinkage post-pass.
    acceptance_tests:
      - npm run test:price-shocks
      - node --test tests/js/test-ingest-costing-integration.mjs
    dependencies: []
    paths_touched:
      - scripts/ingest-costing.mjs
      - lib/priceShocks.ts

  - id: T3
    description: |
      Add a /api/labor/breaks endpoint that records meal/rest break events with
      audit-event emission inside the same db.transaction as the source INSERT.
      Follow the cooling/temp-log rule-module shape exactly (5 files).
    acceptance_tests:
      - npm run test:breaks
      - node --test tests/js/test-breaks-api.mjs
    dependencies: []
    paths_touched:
      - lib/breaks.ts
      - app/api/labor/breaks/route.js
      - app/food-safety/breaks/
      - tests/js/test-break-rules.mjs
      - tests/js/test-breaks-api.mjs
