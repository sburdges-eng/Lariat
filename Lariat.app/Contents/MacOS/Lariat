#!/bin/bash
# Lariat Cockpit — one-click launcher
#
# Starts the Next.js production server (if not already running) and opens
# the app in the default browser. Safe to double-click repeatedly — it
# reuses a running instance.
#
# Logs: ~/Library/Logs/Lariat/lariat.log
# PID:  ~/Library/Logs/Lariat/lariat.pid

set -u

APP_DIR="/Users/seanburdges/Dev/Lariat"
LOG_DIR="$HOME/Library/Logs/Lariat"
LOG="$LOG_DIR/lariat.log"
PIDFILE="$LOG_DIR/lariat.pid"
PORT="${LARIAT_PORT:-3000}"
URL="http://localhost:$PORT"
HOST_URL="http://$(hostname -s).local:$PORT"
WAIT_SECS=45

mkdir -p "$LOG_DIR"

# --- PATH ----------------------------------------------------------------
# Launchd-spawned processes get a minimal PATH. Load common shells so node,
# npm, and (optionally) nvm/homebrew are all visible.
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
if [ -s "$HOME/.nvm/nvm.sh" ]; then
    # shellcheck disable=SC1091
    export NVM_DIR="$HOME/.nvm"; . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
fi

alert() {
    /usr/bin/osascript -e "display alert \"Lariat\" message \"$1\"" >/dev/null 2>&1 || true
}

http_ok() {
    # returns 0 if localhost:PORT answers with any HTTP response
    local code
    code="$(/usr/bin/curl -sS -o /dev/null -w '%{http_code}' --max-time 1 "$URL" 2>/dev/null || echo 000)"
    case "$code" in
        200|301|302|304|307|308|404) return 0 ;;
        *) return 1 ;;
    esac
}

open_browser() {
    /usr/bin/open "$URL"
}

# --- Fast path: already running? ----------------------------------------
if http_ok; then
    open_browser
    exit 0
fi

# --- Pre-flight ----------------------------------------------------------
if [ ! -d "$APP_DIR" ]; then
    alert "Lariat folder not found at $APP_DIR. Move the project or edit Lariat.app/Contents/MacOS/Lariat to point at it."
    exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
    alert "Could not find 'npm' on PATH. Install Node.js (https://nodejs.org) or Homebrew's node and try again."
    exit 1
fi

# --- Start server --------------------------------------------------------
cd "$APP_DIR" || { alert "cd failed: $APP_DIR"; exit 1; }

# Ensure a production build exists. If not, build before starting.
if [ ! -f "$APP_DIR/.next/BUILD_ID" ]; then
    {
        echo "[$(date '+%F %T')] no BUILD_ID, running: npm run build"
        npm run build
    } >> "$LOG" 2>&1 || {
        alert "Build failed. See $LOG"
        /usr/bin/open "$LOG"
        exit 1
    }
fi

{
    echo "[$(date '+%F %T')] starting Lariat on port $PORT"
    echo "[$(date '+%F %T')] PATH=$PATH"
    echo "[$(date '+%F %T')] node=$(command -v node) npm=$(command -v npm)"
} >> "$LOG" 2>&1

# Start in background, detached from this process group
nohup npm run start >> "$LOG" 2>&1 &
SERVER_PID=$!
echo "$SERVER_PID" > "$PIDFILE"
disown "$SERVER_PID" 2>/dev/null || true

# --- Wait for readiness --------------------------------------------------
for _i in $(seq 1 $((WAIT_SECS * 2))); do
    if http_ok; then
        echo "[$(date '+%F %T')] ready at $URL (also $HOST_URL for iPads on the same wifi)" >> "$LOG"
        open_browser
        exit 0
    fi
    # Bail early if the process died
    if ! kill -0 "$SERVER_PID" 2>/dev/null; then
        alert "Lariat server exited. See $LOG"
        /usr/bin/open "$LOG"
        exit 1
    fi
    sleep 0.5
done

alert "Lariat did not respond within $WAIT_SECS s. Showing the log."
/usr/bin/open "$LOG"
exit 1
