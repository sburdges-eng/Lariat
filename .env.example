# Lariat environment template.
# Copy to `.env.local` (gitignored) and fill in. Anything commented uses
# the documented default. Run `curl http://localhost:3001/api/health` to
# verify what's live.
#
# Audit note (2026-05-16, docs/INTEGRATION_AUDIT.md §F2): rebuilt from the
# union of every `process.env.LARIAT_*` read across app/, lib/, scripts/.
# If you add a new env var, add a line here too — there's a CI canary
# (`grep -rh "process.env.LARIAT_" | sort -u`) that flags drift.

# ── PIN gate (required for production) ─────────────────────────────────
LARIAT_PIN=
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LARIAT_PIN_SECRET=

# ── Data layout (required in prod; desktop wrapper auto-sets) ──────────
# LARIAT_DATA_DIR=${HOME}/Library/Application Support/Lariat/data
# LARIAT_DB=${LARIAT_DATA_DIR}/lariat.db
# LARIAT_AUDIT_PATH=${LARIAT_DATA_DIR}/audit/management-actions.jsonl
# LARIAT_ROOT=.                           # script-internal; usually auto-detected
# LARIAT_BASE_URL=http://localhost:3001   # used by some scripts that hit the local API
# LARIAT_TRUST_PROXY=0                    # set to 1 only when behind a reverse proxy

# ── Location scoping ───────────────────────────────────────────────────
# Canonical site id for multi-location rows and discovery metadata. Older
# aliases are still read for one release and emit a one-time warning.
# LARIAT_LOCATION_ID=default
# LARIAT_EXPORT_LOCATION=default          # which location the daily export targets

# ── Kitchen Assistant / LaRi (required for AI surfaces) ───────────────
# LARIAT_OLLAMA_URL=http://127.0.0.1:11434
# LARIAT_OLLAMA_MODEL=lari-the-kitchen-assistant
# LARIAT_OLLAMA_TIMEOUT_MS=45000          # 5000–120000 (clamped at runtime)
# LARIAT_ASSISTANT_TEMPERATURE=0.2        # higher = more creative, lower = more deterministic
# LARIAT_ASSISTANT_MAX_TOKENS=512         # per-response cap (num_predict)
# LARIAT_ASSISTANT_NUM_CTX=4096           # prompt context window
# LARIAT_MORNING_SLACK_WEBHOOK_URL=       # optional: POST /api/morning sends the digest text here
# LARIAT_WHISPER=1                        # optional: local Whisper voice transcription for the
#                                         # hold-to-talk composer. First use downloads ~75 MB
#                                         # (whisper-tiny ONNX) from the Hugging Face hub — enable
#                                         # during a network-connected maintenance window; inference
#                                         # is fully local afterwards. Unset = Web Speech fallback.

# ── Release channel ───────────────────────────────────────────────────
# Test release (v.I.NN.NNN): runs fully offline — Toast / 7shifts / Prism /
# datapack integrations are reported as "disabled" and need no credentials, so
# /api/health stays green without them. Official releases (v.---.--) leave this
# unset (or =0) and expect the vendor creds below to be configured.
# LARIAT_TEST_RELEASE=1
# LARIAT_RELEASE_CHANNEL=test             # stamped into version.json (test|official)

# ── Toast POS (optional — degrades to ingest no-op) ───────────────────
# LARIAT_TOAST_CLIENT_ID=
# LARIAT_TOAST_CLIENT_SECRET=             # SECRET — handle with care
# LARIAT_TOAST_RESTAURANT_GUID=

# ── 7shifts labor (optional) ──────────────────────────────────────────
# Canonical 7shifts API key for health/degraded-mode checks. Older aliases are
# still read for one release and emit a one-time warning.
# LARIAT_7SHIFTS_API_KEY=                 # SECRET

# ── Prism ordering (optional) ─────────────────────────────────────────
# LARIAT_PRISM_USERNAME=
# LARIAT_PRISM_PASSWORD=                  # SECRET

# ── Cloud-bridge sync (optional, multi-venue) ─────────────────────────
# LARIAT_CLOUD_BRIDGE_URL=
# LARIAT_CLOUD_BRIDGE_SECRET=             # SECRET — shared between bridge clients

# ── Cross-host sync peers (optional, multi-tablet venue) ──────────────
# LARIAT_SYNC_PEERS=                      # comma-separated host:port list
# LARIAT_SYNC_PEER_KEY=                   # SECRET — symmetric peer-auth key
# LARIAT_SYNC_TICK_MS=5000                # how often to poll peers
# LARIAT_SYNC_MAX_BODY_BYTES=1048576      # 1 MiB cap on inbound peer payloads
# LARIAT_SYNC_ALLOW_PRIVATE=1             # set to 0 to refuse RFC1918 peer URLs

# ── Outbox drainer (cloud-bridge background worker) ───────────────────
# LARIAT_DRAINER_TICK_MS=2000             # outbox-poll interval
# LARIAT_DRAINER_STALE_AGE_S=300          # rows older than this get re-claimed

# ── Source-of-truth workbook paths (ingest scripts only) ──────────────
# LARIAT_UNIFIED=../_archives/Lariat_Unified_Workbook.xlsx
# LARIAT_OPS=../_archives/lariat_operations_workbook.xlsx
# LARIAT_ANALYTICS=../_archives/lariat_analytics_workbook.xlsx
# LARIAT_COSTING=../_archives/lariat_costing_workbook.xlsx
# LARIAT_SOURCE=                          # default source-workbook override
# LARIAT_PDF=                             # PDF tool config path (build-time)

# ── Python interpreter (optional, ingest only) ────────────────────────
# LARIAT_PYTHON=.venv/bin/python3

# ── E2E test port (override when :3000 is squatted) ───────────────────
# LARIAT_E2E_PORT=3100

# ── Dev tooling overrides (NOT runtime — listed here for grep-discoverability) ──
# LARIAT_ALLOW_ANY_BRANCH=1               # bypass scripts/worktree.sh branch-naming guard (legacy-fixup only)
