    "validate-cache": "node scripts/validate-cache.mjs",
    "export": "node scripts/export.mjs",
    "rebuild-cache": "node scripts/rebuild-cache.mjs",
    "seed-beo": "node scripts/seed-beo.mjs",
    "seed:densities": "python3 scripts/seed_ingredient_densities.py",
    "seed:yields": "python3 scripts/seed_ingredient_yields.py",
    "seed:unit_weights": "python3 scripts/seed_ingredient_unit_weights.py",
    "seed:catch_weights:sysco": "python3 scripts/ingest_catch_weights.py --vendor sysco --csv data/seeds/vendor_pack_weights.csv",
    "seed:catch_weights:shamrock": "python3 scripts/ingest_catch_weights.py --vendor shamrock --csv data/seeds/vendor_pack_weights_shamrock.csv",
    "seed:catch_weights": "npm run seed:catch_weights:sysco && npm run seed:catch_weights:shamrock",
    "seed:webstaurant": "python3 scripts/ingest_webstaurant_purchases.py",
    "seed:kitchen_ops": "python3 scripts/ingest_drive_kitchen_ops.py",
    "seed:catering_menu": "python3 scripts/ingest_catering_menu.py",
    "seed:all": "npm run seed:densities && npm run seed:yields && npm run seed:unit_weights && npm run seed:catch_weights",
    "backup": "node scripts/backup.mjs",
    "propose:bom-vendor-matches": "node --experimental-strip-types scripts/propose-bom-vendor-matches.mjs",
    "propose:plan-restaurant-grind": "node --experimental-strip-types scripts/propose-plan-restaurant-grind.mjs",
    "propose:plan-action-items": "node --experimental-strip-types scripts/propose-plan-action-items.mjs",
    "test:e2e": "npx playwright test",
    "test:temp-log": "node --test tests/js/test-temp-log.mjs",
    "test:temp-log-rules": "node --test tests/js/test-temp-log-rules.mjs",
    "test:temp-log-api": "node --test tests/js/test-temp-log-api.mjs",
    "test:temp-log-route": "node --test tests/js/test-temp-log-route.mjs",
    "test:cooling": "node --test tests/js/test-cooling-rules.mjs",
    "test:date-marks": "node --test tests/js/test-date-mark-rules.mjs",
    "test:sanitizer": "node --test tests/js/test-sanitizer-rules.mjs",
    "test:breaks": "node --test tests/js/test-break-rules.mjs",
    "test:sick-worker": "node --test tests/js/test-sick-worker-rules.mjs",
    "test:receiving-rules": "node --test tests/js/test-receiving-rules.mjs",
    "test:receiving-api": "node --test tests/js/test-receiving-api.mjs",
    "test:service-hours": "node --test tests/js/test-service-hours-api.mjs",
    "test:cleaning-schedule": "node --test tests/js/test-cleaning-schedule-api.mjs",
    "test:calibrations-rules": "node --test tests/js/test-calibrations-rules.mjs",
    "test:calibrations-api": "node --test tests/js/test-calibrations-api.mjs",
    "test:checks-api": "node --test tests/js/test-checks-api.mjs",
    "test:tphc": "node --test tests/js/test-tphc-rules.mjs tests/js/test-tphc-api.mjs",
    "test:tphc-api": "node --test tests/js/test-tphc-api.mjs",
    "test:pin-cookie": "node --test tests/js/test-pin-cookie-hmac.mjs",
    "test:rules": "node --test tests/js/test-temp-log.mjs tests/js/test-cooling-rules.mjs tests/js/test-date-mark-rules.mjs tests/js/test-sanitizer-rules.mjs tests/js/test-break-rules.mjs tests/js/test-sick-worker-rules.mjs tests/js/test-tphc-rules.mjs",
    "test:schema": "node --test tests/js/test-schema-migrations.mjs",
    "test:ingredient-key": "node --test tests/js/test-ingredient-key-parity.mjs",
    "test:ingest-yields": "node --experimental-strip-types --test tests/js/test-ingest-costing-yields.mjs",
    "test:yield-math": "node --experimental-strip-types --test tests/js/test-ingest-costing-yield-math.mjs",
    "test:unit-convert": "node --experimental-strip-types --test tests/js/test-unit-convert-parity.mjs",
    "test:t4-integration": "node --experimental-strip-types --test tests/js/test-t4-unit-convert-integration.mjs",
