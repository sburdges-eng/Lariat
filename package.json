    "test:pack-size-detect": "node --experimental-strip-types --test tests/js/test-pack-size-detect.mjs",
    "test:ingredient-masters": "node --experimental-strip-types --test tests/js/test-ingredient-masters.mjs",
    "test:t8-cooking-shrinkage": "node --experimental-strip-types --test tests/js/test-t8-cooking-shrinkage.mjs",
    "test:t9-benchmarks": "node --experimental-strip-types --test tests/js/test-t9-benchmarks.mjs",
    "test:propose-bom-vendor-matches": "node --experimental-strip-types --test tests/js/test-propose-bom-vendor-matches.mjs",
    "test:propose-plan-restaurant-grind": "node --experimental-strip-types --test tests/js/test-propose-plan-restaurant-grind.mjs",
    "test:propose-plan-action-items": "node --experimental-strip-types --test tests/js/test-propose-plan-action-items.mjs"
