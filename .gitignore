# ── Data Pack (external SSD via symlink) ──────────────────────
# Raw downloads, extracted data, indexes — all on external drive
data/lariat-data/raw/
data/lariat-data/normalized/
data/lariat-data/indexes/
# Keep manifests tracked (small JSON metadata)
!data/lariat-data/manifests/

# ── Toast API (weekly pull) ──────────────────────────────────
# Token cache holds the bearer JWT — short-lived but sensitive.
# Snapshots are raw paginated JSONL responses for the last N days;
# they can hit hundreds of MB on busy weeks. Both belong off-repo.
data/toast-api/

# ── Coverage reports (dish_components gap, weekly launchd run) ─
# Generated by scripts/coverage-weekly.mjs — dish names + qty-sold
# pairs are restaurant ops data and shouldn't land in git history.
data/coverage-reports/

# ── Pre-migration DB snapshots ────────────────────────────────
# Created by backfill/phase scripts before destructive migrations.
# Local-only safety net; restored by hand if needed.
*.bak-pre-*

# ── Ingest cache (regenerable from source) ────────────────────
data/cache/*.json

# ── Design archives (binary zips paired with extracted folders) ─
design/*.zip
design/Lairiat-VI/
design/Lariat2/
design/.DS_Store
design/cockpit-v2.html

# ── Pitch / sales presentation PDFs ───────────────────────────
# Sample invoice exports used for the deck — restaurant ops data.
Presentation/

# ── Equipment manuals / spec sheets parked in data/ ───────────
# Reference PDFs for kitchen hardware (slicers, ranges, warranties).
# Useful locally; not source-controlled binaries.
data/*.pdf

# ── Multi-agent worktrees (created by /orchestrate) ───────────
.claude-worktrees/

# ── Local MCP server config (hardcoded user path) ─────────────
.mcp.json

# ── Generated test fixtures ──────────────────────────────────
tests/python/fixtures/shows_minimal.xlsx
tests/js/.tmp-shows-*.db*
